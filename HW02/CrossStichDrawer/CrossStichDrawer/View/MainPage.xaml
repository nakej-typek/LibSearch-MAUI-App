<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CrossStichDrawer.ViewModel"
             x:Class="CrossStichDrawer.View.MainPage"
             Title="Cross Stitch Drawer">
    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*" Padding="10" RowSpacing="10">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Spacing="10">
            <Label Text="Width:" VerticalOptions="Center"/>
            <Entry Text="{Binding GridWidth}" WidthRequest="60" Keyboard="Numeric"/>
            <Label Text="Height:" VerticalOptions="Center"/>
            <Entry Text="{Binding GridHeight}" WidthRequest="60" Keyboard="Numeric"/>
            <Button Text="New Pattern" Command="{Binding CreateNewPatternCommand}"/>
            <Picker x:Name="ColorPicker" Title="Select DMC Color"
                    ItemsSource="{Binding AvailableColors}"
                    SelectedItem="{Binding SelectedColor}"/>
            <Button Text="Save" Command="{Binding SavePatternCommand}"/>
            <Button Text="Load" Command="{Binding LoadPatternCommand}"/>
        </HorizontalStackLayout>

        <!-- Pattern grid -->
        <ScrollView Grid.Row="1" Orientation="Both">
            <Grid x:Name="PatternGrid" BackgroundColor="Gray"/>
        </ScrollView>

    </Grid>

</ContentPage>
