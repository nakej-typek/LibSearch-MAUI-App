<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LibSearch.App.ViewModels"
             xmlns:views="clr-namespace:LibSearch.App.Views"
             x:Class="LibSearch.App.Views.SavedListPage"
             x:DataType="vm:SavedListViewModel"
             Title="Saved passages">
    <Grid Padding="20,14,20,20" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Button Grid.Column="0" Text="← Back" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" />
            <Label Grid.Column="1" Text="Saved passages" Style="{StaticResource SubpageTitle}" />
            <Button Grid.Column="2" Text="Export" Command="{Binding ExportCommand}" IsEnabled="{Binding IsNotBusy}" />
        </Grid>

        <views:FilterBarView Grid.Row="1" BindingContext="{Binding Filter}" />

        <StackLayout Grid.Row="2" Orientation="Horizontal" Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding StatusMessage}" Style="{StaticResource Caption}" VerticalOptions="Center" />
        </StackLayout>

        <CollectionView Grid.Row="3" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No saved passages match your filter." Style="{StaticResource Caption}" HorizontalOptions="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:SavedPassageVm">
                    <Border Style="{StaticResource CardCompact}" Margin="0,4">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Text="{Binding DocumentTitle}" Style="{StaticResource Subheading}" />
                            <Label Grid.Row="1" Text="{Binding Entity.Excerpt}" FontSize="13" LineBreakMode="WordWrap" />
                            <Label Grid.Row="2" Text="{Binding Entity.Note}" Style="{StaticResource Caption}" IsVisible="{Binding Entity.Note, Converter={StaticResource StringNotEmptyConverter}}" />
                            <Label Grid.Row="3" Text="{Binding TagsDisplay, StringFormat='Tags: {0}'}" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandAccent}}" IsVisible="{Binding TagsDisplay, Converter={StaticResource StringNotEmptyConverter}}" />
                            <HorizontalStackLayout Grid.Row="4" Spacing="6">
                                <Button Text="Edit" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="10,5"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SavedListViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Delete" Style="{StaticResource DangerButton}" FontSize="11" Padding="10,5"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SavedListViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
