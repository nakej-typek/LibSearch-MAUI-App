<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LibSearch.App.ViewModels"
             x:Class="LibSearch.App.Views.ReaderPage"
             x:DataType="vm:ReaderViewModel"
             Title="{Binding DocumentTitle}">
    <Grid>
        <Grid Padding="20,14,20,20" RowDefinitions="Auto,*" RowSpacing="14">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0" Text="← Back" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" />
                <Label Grid.Column="1" Text="{Binding DocumentTitle}" Style="{StaticResource SubpageTitle}" />
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="20">

                <CollectionView Grid.Column="0"
                                x:Name="ChunksView"
                                ItemsSource="{Binding Chunks}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChunkItem">
                            <Border Margin="0,4" Padding="14"
                                    BackgroundColor="{Binding IsHighlighted, Converter={StaticResource HighlightBackgroundConverter}}"
                                    Stroke="{AppThemeBinding Light={StaticResource BorderNeutral}, Dark={StaticResource BorderNeutralDark}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                <Label Text="{Binding Text}" FontSize="14" LineHeight="1.45" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                    <Entry Grid.Row="0" Placeholder="Ask in natural language..." Text="{Binding Prompt}" ReturnCommand="{Binding SearchCommand}" />
                    <Button Grid.Row="1" Text="Search" Command="{Binding SearchCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <StackLayout Grid.Row="2" Orientation="Horizontal" Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                        <Label Text="{Binding StatusMessage}" Style="{StaticResource Caption}" VerticalOptions="Center" />
                    </StackLayout>
                    <CollectionView Grid.Row="3" ItemsSource="{Binding Results}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="Results will appear here." Style="{StaticResource Caption}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PassageResultVm">
                                <Border Style="{StaticResource CardCompact}" Margin="0,4">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <Label Grid.Row="0" Text="{Binding Rank, StringFormat='Result #{0}'}" Style="{StaticResource Caption}" FontAttributes="Bold" />
                                        <Label Grid.Row="1" Text="{Binding Text}" FontSize="13" LineBreakMode="WordWrap" MaxLines="6" />
                                        <HorizontalStackLayout Grid.Row="2" Spacing="6">
                                            <Button Text="Show in text" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="10,5"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReaderViewModel}}, Path=SelectResultCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Text="Save" FontSize="11" Padding="10,5"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReaderViewModel}}, Path=BeginSaveCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

            </Grid>
        </Grid>

        <Grid IsVisible="{Binding IsSaveDialogOpen}" BackgroundColor="#80000000" Padding="0">
            <Border Style="{StaticResource Card}"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="24" WidthRequest="500">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Save passage" Style="{StaticResource SectionHeading}" />
                    <Label Text="Note" Style="{StaticResource Caption}" />
                    <Editor Text="{Binding SaveNote}" HeightRequest="100" AutoSize="TextChanges" />
                    <Label Text="Tags (comma-separated)" Style="{StaticResource Caption}" />
                    <Entry Text="{Binding SaveTags}" Placeholder="e.g. anarchy, ethics, key-passage" />
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                        <Button Text="Cancel" Command="{Binding CancelSaveCommand}" Style="{StaticResource GhostButton}" />
                        <Button Text="Save" Command="{Binding ConfirmSaveCommand}" IsEnabled="{Binding IsNotBusy}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
