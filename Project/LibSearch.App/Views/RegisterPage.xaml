<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LibSearch.App.ViewModels"
             x:Class="LibSearch.App.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Register"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*,440,*">
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Padding="32">
            <VerticalStackLayout Spacing="14">
                <Label Text="LibSearch" Style="{StaticResource PageTitle}" HorizontalOptions="Center" />
                <Label Text="Create an account" Style="{StaticResource Caption}" HorizontalOptions="Center" />
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderNeutral}, Dark={StaticResource BorderNeutralDark}}" Margin="0,8" />
                <Label Text="Username" Style="{StaticResource Caption}" />
                <Entry Placeholder="min. 3 characters" Text="{Binding Username}" />
                <Label Text="Password" Style="{StaticResource Caption}" />
                <Entry Placeholder="min. 6 characters" IsPassword="True" Text="{Binding Password}" />
                <Label Text="Confirm password" Style="{StaticResource Caption}" />
                <Entry Placeholder="repeat the password" IsPassword="True" Text="{Binding PasswordConfirm}" />
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}" />
                <Button Text="Register" Command="{Binding RegisterCommand}" IsEnabled="{Binding IsNotBusy}" />
                <Button Text="Back to login" Command="{Binding GoToLoginCommand}" Style="{StaticResource GhostButton}" />
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
