<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LibSearch.App.ViewModels"
             x:Class="LibSearch.App.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Login"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*,440,*">
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Padding="32">
            <VerticalStackLayout Spacing="14">
                <Label Text="LibSearch" Style="{StaticResource PageTitle}" HorizontalOptions="Center" />
                <Label Text="Sign in to continue" Style="{StaticResource Caption}" HorizontalOptions="Center" />
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderNeutral}, Dark={StaticResource BorderNeutralDark}}" Margin="0,8" />
                <Label Text="Username" Style="{StaticResource Caption}" />
                <Entry Placeholder="your-username" Text="{Binding Username}" />
                <Label Text="Password" Style="{StaticResource Caption}" />
                <Entry Placeholder="••••••" IsPassword="True" Text="{Binding Password}" />
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}" />
                <Button Text="Login" Command="{Binding LoginCommand}" IsEnabled="{Binding IsNotBusy}" />
                <Button Text="Create account" Command="{Binding GoToRegisterCommand}" Style="{StaticResource GhostButton}" />
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
