<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LibSearch.App.ViewModels"
             xmlns:models="clr-namespace:LibSearch.App.Models.Entities"
             x:Class="LibSearch.App.Views.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Title="Library">
    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <Label Grid.Column="0" Text="{Binding CurrentUsername, StringFormat='Signed in as {0}'}" FontSize="14" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="History" Command="{Binding OpenHistoryCommand}" Style="{StaticResource GhostButton}" />
                <Button Grid.Column="2" Text="Saved" Command="{Binding OpenSavedCommand}" Style="{StaticResource GhostButton}" />
                <Button Grid.Column="3" Text="Stats" Command="{Binding OpenStatsCommand}" Style="{StaticResource GhostButton}" />
                <Button Grid.Column="4" Text="Logout" Command="{Binding LogoutCommand}" Style="{StaticResource GhostButton}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="12">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Your library" Style="{StaticResource PageTitle}" />
                <Button Grid.Column="1" Text="Upload .txt" Command="{Binding UploadCommand}" IsEnabled="{Binding IsNotBusy}" />
            </Grid>

            <StackLayout Grid.Row="1" Orientation="Horizontal" Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                <Label Text="{Binding StatusMessage}" Style="{StaticResource Caption}" VerticalOptions="Center" />
            </StackLayout>

            <CollectionView Grid.Row="2" ItemsSource="{Binding Documents}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource Card}" Padding="32" HorizontalOptions="Center" VerticalOptions="Center" MaximumWidthRequest="400">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Library is empty" Style="{StaticResource SectionHeading}" HorizontalOptions="Center" />
                            <Label Text="Upload a .txt file to get started." Style="{StaticResource Caption}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TextDocument">
                        <Border Style="{StaticResource CardCompact}" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Title}" Style="{StaticResource Subheading}" />
                                    <Label Text="{Binding CharCount, StringFormat='{0:N0} characters'}" Style="{StaticResource Caption}" />
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenCommand}" CommandParameter="{Binding .}" />
                                    </VerticalStackLayout.GestureRecognizers>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding IngestedAt, StringFormat='● indexed', TargetNullValue='○ pending'}" TextColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandAccent}}" VerticalOptions="Center" FontSize="12" />
                                <Button Grid.Column="2" Text="Rename" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=RenameCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="3" Text="Delete" Style="{StaticResource DangerButton}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </Grid>
</ContentPage>
