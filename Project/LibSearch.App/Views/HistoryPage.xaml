<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LibSearch.App.ViewModels"
             xmlns:views="clr-namespace:LibSearch.App.Views"
             x:Class="LibSearch.App.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="Search history">
    <Grid Padding="20,14,20,20" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Text="← Back" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" />
            <Label Grid.Column="1" Text="Search history" Style="{StaticResource SubpageTitle}" />
        </Grid>

        <views:FilterBarView Grid.Row="1" BindingContext="{Binding Filter}" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No matching searches." Style="{StaticResource Caption}" HorizontalOptions="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:HistoryItemVm">
                    <Border Style="{StaticResource CardCompact}" Margin="0,4">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Entity.Prompt}" Style="{StaticResource Subheading}" />
                                <Label Text="{Binding DocumentTitle}" FontSize="13" />
                                <Label Text="{Binding Entity.ExecutedAt, StringFormat='{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding Entity.ResultCount, StringFormat='{0} results'}" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Rerun" VerticalOptions="Center"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=RerunCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
