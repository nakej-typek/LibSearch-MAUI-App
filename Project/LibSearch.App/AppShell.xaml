<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LibSearch.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LibSearch.App.Views"
    FlyoutBehavior="Disabled">

    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="register" ContentTemplate="{DataTemplate views:RegisterPage}" />
    <ShellContent Route="library" ContentTemplate="{DataTemplate views:LibraryPage}" />

</Shell>
